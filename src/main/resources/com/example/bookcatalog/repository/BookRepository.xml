<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.bookcatalog.repository.BookRepository">

    <resultMap id="bookResultMap" type="com.example.bookcatalog.domain.entity.Book">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="author" column="author"/>
        <result property="isbn" column="isbn"/>
        <result property="publishedDate" column="published_date"/>
        <result property="description" column="description"/>
        <result property="available" column="available"/>
    </resultMap>

    <select id="findById" resultMap="bookResultMap">
        SELECT * FROM books WHERE id = #{id}
    </select>

    <select id="findByIsbn" resultMap="bookResultMap">
        SELECT * FROM books WHERE isbn = #{isbn}
    </select>

    <select id="existsByIsbn" resultType="boolean">
        SELECT CASE WHEN COUNT(1) > 0 THEN 1 ELSE 0 END FROM books WHERE isbn = #{isbn}
    </select>

    <select id="findAll" resultMap="bookResultMap">
        SELECT * FROM books
    </select>

    <select id="findByAuthorContainingIgnoreCase" resultMap="bookResultMap">
        SELECT * FROM books WHERE LOWER(author) LIKE LOWER(CONCAT('%', #{author}, '%'))
    </select>

    <select id="findByTitleContainingIgnoreCase" resultMap="bookResultMap">
        SELECT * FROM books WHERE LOWER(title) LIKE LOWER(CONCAT('%', #{title}, '%'))
    </select>

    <select id="findByAvailable" resultMap="bookResultMap">
        SELECT * FROM books WHERE available = #{available}
    </select>

    <insert id="save" useGeneratedKeys="true" keyProperty="id" keyColumn="id">
        INSERT INTO books (title, author, isbn, published_date, description, available)
        VALUES (#{title}, #{author}, #{isbn}, #{publishedDate}, #{description}, #{available})
    </insert>

    <update id="update">
        UPDATE books
        SET title = #{title},
            author = #{author},
            isbn = #{isbn},
            published_date = #{publishedDate},
            description = #{description},
            available = #{available}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM books WHERE id = #{id}
    </delete>

</mapper>